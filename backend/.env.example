# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS committer le fichier .env dans git

# Base de donnees Supabase (PostgreSQL)
# Disponible dans : Supabase > Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres:[MOT_DE_PASSE]@db.[REF_PROJET].supabase.co:5432/postgres"

# Port du serveur (optionnel, 3000 par defaut)
PORT=3000

# Environnement
NODE_ENV=development
